@prefix atom: <http://lv2plug.in/ns/ext/atom#> .
@prefix doap: <http://usefulinc.com/ns/doap#> .
@prefix lv2:  <http://lv2plug.in/ns/lv2core#> .
@prefix midi: <http://lv2plug.in/ns/ext/midi#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<https://goa.in.rs/MireBass>
    a lv2:Plugin , lv2:InstrumentPlugin ;
    doap:name "MireBass" ;
    lv2:port [
        a lv2:ControlPort , lv2:InputPort ; lv2:index 0 ; lv2:symbol "wave" ; lv2:name "Square" ;
        lv2:default 0 ; lv2:minimum 0 ; lv2:maximum 1 ; lv2:portProperty lv2:toggled
    ] , [
        a lv2:ControlPort , lv2:InputPort ; lv2:index 1 ; lv2:symbol "f1" ; lv2:name "Start Hz" ;
        lv2:default 12000.0 ; lv2:minimum 500.0 ; lv2:maximum 20000.0
    ] , [
        a lv2:ControlPort , lv2:InputPort ; lv2:index 2 ; lv2:symbol "f2" ; lv2:name "Mid Hz" ;
        lv2:default 400.0 ; lv2:minimum 30.0 ; lv2:maximum 5000.0
    ] , [
        a lv2:ControlPort , lv2:InputPort ; lv2:index 3 ; lv2:symbol "f3" ; lv2:name "End Hz" ;
        lv2:default 50.0 ; lv2:minimum 50.0 ; lv2:maximum 300.0
    ] , [
        a lv2:ControlPort , lv2:InputPort ; lv2:index 4 ; lv2:symbol "t1" ; lv2:name "Time 1 (ms)" ;
    	lv2:default 50.0 ; lv2:minimum 0.0 ; lv2:maximum 200.0 ;
	units:unit units:ms
    ] , [
        a lv2:ControlPort , lv2:InputPort ; lv2:index 5 ; lv2:symbol "c1" ; lv2:name "Curve 1" ;
        lv2:default 0.5 ; lv2:minimum 0.0 ; lv2:maximum 1.0
    ] , [
        a lv2:ControlPort , lv2:InputPort ; lv2:index 6 ; lv2:symbol "t2" ; lv2:name "Time 2 (ms)" ;
	lv2:default 20.0 ; lv2:minimum 0.0 ; lv2:maximum 100.0 ;
	units:unit units:ms
    ] , [
        a lv2:ControlPort , lv2:InputPort ; lv2:index 7 ; lv2:symbol "c2" ; lv2:name "Curve 2" ;
        lv2:default 0.5 ; lv2:minimum 0.0 ; lv2:maximum 1.0
    ] , [
        a lv2:ControlPort , lv2:InputPort ; lv2:index 8 ; lv2:symbol "res" ; lv2:name "Resonance" ;
        lv2:default 0.0 ; lv2:minimum 0.0 ; lv2:maximum 0.4
    ] , [
        a lv2:ControlPort , lv2:InputPort ; lv2:index 9 ; lv2:symbol "vol" ; lv2:name "Volume" ;
        lv2:default 0.5 ; lv2:minimum 0.0 ; lv2:maximum 1.0
    ] , [
        a lv2:InputPort , atom:AtomPort ; atom:bufferType atom:Sequence ; atom:supports midi:MidiEvent ;
        lv2:index 10 ; lv2:symbol "midi_in" ; lv2:name "MIDI In"
    ] , [
        a lv2:AudioPort , lv2:OutputPort ; lv2:index 11 ; lv2:symbol "out" ; lv2:name "Out"
    ] .